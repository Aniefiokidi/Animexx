# Copy this file to .env.local and fill in real values.
# Brevo SMTP settings (recommended for this project)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_brevo_smtp_login
SMTP_PASS=your_brevo_smtp_key_or_api_key
FROM_EMAIL=booking@yourdomain.com
TO_EMAIL=office@yourdomain.com

# Optional Brevo aliases (route.ts also supports these)
# BREVO_SMTP_HOST=smtp-relay.brevo.com
# BREVO_SMTP_PORT=587
# BREVO_SMTP_LOGIN=your_brevo_smtp_login
# BREVO_SMTP_KEY=your_brevo_smtp_key
# BREVO_API_KEY=your_brevo_api_key
# BREVO_FROM_EMAIL=booking@yourdomain.com
# OFFICE_EMAIL=office@yourdomain.com

# Optional Mailtrap API fallback (for staging/testing only)
# MAILTRAP_API_TOKEN=your_mailtrap_token

# Notes:
# - Do NOT commit real credentials to source control. Keep them only in .env.local.
